#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	# Nothing to build — venv is created at install time (postinst)

override_dh_auto_install:
	install -d $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper
	cp -r data_scraper $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper/
	cp -r resources $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper/
	cp requirements.txt $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper/
	cp -r vendor $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper/

	# OAuth credentials — local dir (dev builds) or OBS SOURCES dir
	install -d $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper/credentials
	for dir in credentials /usr/src/packages/SOURCES; do \
		for f in $$dir/google.json $$dir/microsoft.json; do \
			if [ -f "$$f" ]; then \
				install -m 644 "$$f" $(CURDIR)/debian/cloud-scraper/opt/openfactory/cloud-scraper/credentials/; \
			fi; \
		done; \
	done

	# Desktop entry + launcher script
	install -d $(CURDIR)/debian/cloud-scraper/usr/share/applications
	install -m 644 debian/cloud-scraper.desktop $(CURDIR)/debian/cloud-scraper/usr/share/applications/
	install -d $(CURDIR)/debian/cloud-scraper/usr/bin
	install -m 755 debian/cloud-scraper.sh $(CURDIR)/debian/cloud-scraper/usr/bin/cloud-scraper

override_dh_auto_clean:
	rm -rf debian/venv
	dh_auto_clean
